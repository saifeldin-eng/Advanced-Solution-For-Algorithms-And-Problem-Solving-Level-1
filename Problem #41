#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadPositiveNumber(string Message) {
	
	int number = 0;

	do 
	{
		cout << Message;
		cin >> number;
		cout << endl;

	} while (number <= 0);
	
	return number;
}
float HoursToWeeks(float hours){

	float week = (hours / 24) / 7;
	return week;
}
float HoursToDays(float hours){

	float Days = hours / 24;
	return Days;
}

int main() {

	int Hours = ReadPositiveNumber("Please Enter The Number Of Hours: ");

	cout << Hours << " hour = " << HoursToWeeks(Hours) << " Week" << endl;
	cout << Hours << " hour = " << HoursToDays(Hours) << " Day" << endl;



	return 0;
}
