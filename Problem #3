#include <iostream>
#include <string>

using namespace std;

int ReadNum() {
	int num;
	cout << "Enter Your Number: ";
	cin >> num;
	return num;
}
void evenOddCheck(int num) {

	if ((num % 2) == 0) {

		cout << "The Number is: even";
	}
	else if ((num % 2) == 1) {
		cout << "The Number is: odd";
	}
}

int main() {
	
 evenOddCheck(ReadNum());
	
	
}
