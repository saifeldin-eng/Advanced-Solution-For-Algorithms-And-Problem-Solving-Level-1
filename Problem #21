#include <iostream>
#include <string>
#include <cmath>
using namespace std;

float ReadCircumFerence() {
	float CircumFerence;


	cout << "Enter The Square Length: ";
	cin >> CircumFerence;
	cout << endl;

	return CircumFerence;
}

float CircleAreaByCircumFerence(float CircumFerence) {

	float PI = 3.14;

	return  (pow(CircumFerence, 2)) / (4 * PI);
}

void PrintResult(float CircleArea) {

	cout << "\n Circle Area = " << CircleArea << endl << endl;
}

int main() {


	
	PrintResult(CircleAreaByCircumFerence(ReadCircumFerence()));
	
	return 0;
}
