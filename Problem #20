#include <iostream>
#include <string>
#include <cmath>
using namespace std;

float ReadSquareSide() {
	float SquareSide;


	cout << "Enter The Square Length: ";
	cin >> SquareSide;
	cout << endl;

	return SquareSide;
}

float CircleAreaInscribedInSquare(float SquareSide) {

	float PI = 3.14;

	return  (PI * pow(SquareSide, 2)) / 4;
}

void PrintResult(float CircleArea) {

	cout << "\n Circle Area = " << CircleArea << endl << endl;
}

int main() {


	
	PrintResult(CircleAreaInscribedInSquare(ReadSquareSide()));
	
	return 0;
}
