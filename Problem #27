#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadNumber(){

	int N;

	cout << "Please Enter Your Number: ";
	cin >> N;
	cout << endl;

	return N;

}
void PrintFromNumTo1_UsingForLoop(int N) {
	cout << "\n For Loop \n";
	for (int i = N; i >= 1; i--) {

		cout << i << endl;
	}
}
void PrintFromNumTo1_UsingDoWhile(int N){

	cout << "\n Do While Loop \n";
	int counter = N + 1;

	do{
		counter--;
		cout << counter << endl;
	
	} while (counter > 1);
}
void PrintFromNumTo1_UsingWhile(int N){
	cout << "\n While Loop \n";
	int counter = N + 1;

	while (counter > 1) {

		counter--;
		cout << counter << endl;

	}


}

int main() {

	int Number = ReadNumber();

	PrintFromNumTo1_UsingForLoop(Number);
	PrintFromNumTo1_UsingDoWhile(Number);
	PrintFromNumTo1_UsingWhile(Number);
	
	return 0;
}
