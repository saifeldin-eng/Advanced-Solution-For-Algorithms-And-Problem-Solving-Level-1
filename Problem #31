#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadPositiveNumber() {

	int num;
	do {

		cout << "Please Enter a Positive Number: ";
		cin >> num;
		cout << endl;

	} while (num <= 0);


	return num;
}

int PowerOf2(int base) {
	return base * base;
}
int PowerOf3(int base) {
	return base * base * base;
}
int PowerOf4(int base) {
	return base * base * base * base;
}

void PrintPowerResult(int num) {

	cout << "Power Of 2 is: " << PowerOf2(num) << endl;
	cout << "Power Of 3 is: " << PowerOf3(num) << endl;
	cout << "Power Of 4 is: " << PowerOf4(num) << endl;

}

int main() {

	PrintPowerResult(ReadPositiveNumber());

	return 0;
}
