#include <iostream>
#include <string>
using namespace std;

struct strDriverInfo {

	int age = 0;
	bool hasdreiverLicense = 0;
	bool hasRecomendation = 0;
};
strDriverInfo ReadDriverInfo(){
 
	strDriverInfo DriverInfo;

	cout << "Do you Have Intermediary? (0 or 1): ";
	cin >> DriverInfo.hasRecomendation;
	cout << endl;

	if (DriverInfo.hasRecomendation == 0) {

		cout << "Enter Your Age: ";
		cin >> DriverInfo.age;
		cout << endl;

		cout << "Do You Have Dreiver License? (0 or 1): ";
		cin >> DriverInfo.hasdreiverLicense;
		cout << endl;
	}


	return DriverInfo;

}
bool CheckInfoAndReturnState(strDriverInfo DriverInfo) {
	
	return (DriverInfo.age >= 21 && DriverInfo.hasdreiverLicense || DriverInfo.hasRecomendation);
}
void PrintResult(strDriverInfo DreiverInfo) {
	
	if (CheckInfoAndReturnState(DreiverInfo)) {

		cout << "\nAccepted\n";
		

	}
	else {
		cout << "\nRejected\n";
	}
}

int main() {


	PrintResult(ReadDriverInfo());


	return 0;
}
