#include <iostream>
#include <string>
#include <cmath>
using namespace std;

struct stCalculatorContent{
	int firstNumber = 0;
	int SecondNumber = 0;
	string Operator = "0";
};

stCalculatorContent ReadCalculatorComponent() {
	stCalculatorContent CalculatorContent;

	cout << "Enter The First Number: ";
	cin >> CalculatorContent.firstNumber;
	cout << endl;
	do {

		cout << "Enter The Operator (+ , - , * , / , %): ";
		cin >> CalculatorContent.Operator;
		cout << endl;

	}while   (CalculatorContent.Operator != "+" 
		    && CalculatorContent.Operator != "-" 
		    && CalculatorContent.Operator != "*" 
		    && CalculatorContent.Operator != "/" 
		    && CalculatorContent.Operator != "%");
	

	cout << "Enter The Second Number: ";
	cin >> CalculatorContent.SecondNumber;
	cout << endl;

	return CalculatorContent;
}

int Calculator(stCalculatorContent CalculatorContent){

	if (CalculatorContent.Operator == "-")
		return CalculatorContent.firstNumber - CalculatorContent.SecondNumber;

	else if(CalculatorContent.Operator == "+")
		return CalculatorContent.firstNumber + CalculatorContent.SecondNumber;

	else if(CalculatorContent.Operator == "*")
		return CalculatorContent.firstNumber * CalculatorContent.SecondNumber;

	else if(CalculatorContent.Operator == "/")
		return CalculatorContent.firstNumber / CalculatorContent.SecondNumber;

	else if(CalculatorContent.Operator == "%")
		return CalculatorContent.firstNumber % CalculatorContent.SecondNumber;


}

void PrintResult(stCalculatorContent CalculatorContent) {

	cout << Calculator(CalculatorContent) << endl ;
}

int main() {

	PrintResult(ReadCalculatorComponent());

}
