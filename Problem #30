#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadNumber() {

	int num;
	cout << "Enter Your Number: ";
	cin >> num;
	cout << endl;

	return num;
}
int factorialOf(int num){
	int f = 1;

	for (int i = 1; i <= num; i++) {
		f *= i;
}
	return f;
}
void PrintResult(int f){

	cout << f << endl;
}

int main() {


	PrintResult(factorialOf(ReadNumber()));

	return 0;
}
