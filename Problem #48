#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadPositiveNumber(string Message) {

	int number = 0;

	do
	{
		cout << Message;
		cin >> number;
		cout << endl;

	} while (number <= 0);

	return number;
}

int MonthlyInstallment(int LoanAmount, int NumOfMonths) {

	return LoanAmount / NumOfMonths;
}

int main() {

	int LoanAmount = ReadPositiveNumber("Enter The Loan Amount: ");
	int NumOfMonths = ReadPositiveNumber("Enter The Number Of Months: ");

	cout << "You must pay " << MonthlyInstallment(LoanAmount, NumOfMonths)
		<< " every month to settle the loan."
		<< endl;


	return 0;
}
