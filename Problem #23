float CircleAreaInscribedInArbitraryTringle(float a , float b , float c) {

	float P = (a + b + c) / 2;
	float PI = 3.14;

	return PI * pow((a * b * c) / (4 * sqrt(P * (P - a) * (P - b) * (P - c))), 2);
}

void PrintResult(float CircleArea) {

	cout << "\n Circle Area = " << CircleArea << endl << endl;
}

