#include <iostream>
#include <string>
#include <cmath>
using namespace std;

float ReadDiameter() {
	float D;


	cout << "Enter The Radius: ";
	cin >> D;
	cout << endl;

	return D;
}

float CircleAreaByDiameter(float Diameter) {

	float PI = 3.14;

	return PI * (pow(Diameter, 2)/4);
}

void PrintResult(float CircleArea) {

	cout << "\n Circle Area = " << CircleArea << endl << endl;
}

int main() {


	
	PrintResult(CircleAreaByDiameter(ReadDiameter()));
	
	return 0;
}
