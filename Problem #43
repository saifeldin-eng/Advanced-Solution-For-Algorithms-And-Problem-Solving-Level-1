#include <iostream>
#include <string>
#include <cmath>
using namespace std;

struct stSecondsPer {

const float Day = 24 * 60 * 60;
const float Hour = 60 * 60;
const float Minuts= 60;

};
struct stTimeVariables {
	float Days, Hours, Minuts, Seconds;
};

int ReadPositiveNumber(string Message) {
	
	int number = 0;

	do 
	{
		cout << Message;
		cin >> number;
		cout << endl;

	} while (number <= 0);
	
	return number;
}

stTimeVariables SecondsToTimeVariables(float TotalSeconds) {

	stSecondsPer      SecondsPer;
	stTimeVariables   TimeVariables;

	int Reminder = 0;


	TimeVariables.Days = TotalSeconds / SecondsPer.Day;
	Reminder = (TimeVariables.Days - floor(TimeVariables.Days)) * 24 * 60 * 60;

	TimeVariables.Hours = Reminder / SecondsPer.Hour;
	Reminder = (TimeVariables.Hours - floor(TimeVariables.Hours)) * 60 * 60;

	TimeVariables.Minuts = Reminder / SecondsPer.Minuts;
	Reminder = (TimeVariables.Minuts - floor(TimeVariables.Minuts)) * 60;

	TimeVariables.Seconds = Reminder;

	return TimeVariables;
}

void PrintTimeVariables(stTimeVariables TimeVariables) {

	cout << floor(TimeVariables.Days) << ":"
		<< floor(TimeVariables.Hours) << ":"
		<< floor(TimeVariables.Minuts) << ":"
		<< floor(TimeVariables.Seconds) << endl;
}

int main() {

	PrintTimeVariables(SecondsToTimeVariables(ReadPositiveNumber("Please Enter The Total Seconds: ")));

	return 0;
}
