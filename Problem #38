#include <iostream>
#include <string>
#include <cmath>
using namespace std;

enum  enPrimeOrNot {Prime,NotPrime};

int ReadNumber(string Message) {
	
	float number = 0;

	cout << Message;
	cin >> number;
	cout << endl;

	return number;
}

enPrimeOrNot CheckPrimeNumber(int num) {

	int HalfNum = num / 2;

	if (num == 1)
		return enPrimeOrNot::NotPrime;
	else if (num == 2)
		return enPrimeOrNot::Prime;

	for (int i = 1; i <= HalfNum; i++) {
		
		if (num % i == 0) {
			return enPrimeOrNot::NotPrime;
		}
	}
        return enPrimeOrNot::Prime;
}

string ResultOfCheck(enPrimeOrNot PrimeOrNot) {

	switch (PrimeOrNot) {
	case enPrimeOrNot::Prime:
		return "Prime Number";
	case enPrimeOrNot::NotPrime:
		return "Not Prime Number";
	default:
		return "Eror in Result Function";
	}

}

void PrimeOrNot(int num) {

	string result = ResultOfCheck(CheckPrimeNumber(num));

	cout << "The Number " << num << " is " << result << endl;;

}

int main() {

	int number = ReadNumber("Please Enter Your Number: ");

	PrimeOrNot(number);

}
