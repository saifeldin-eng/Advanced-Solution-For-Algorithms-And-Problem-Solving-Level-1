#include <iostream>
#include <string>
#include <cmath>
using namespace std;

float ReadPositiveNumber(string Message) {
	
	int number = 0;

	do 
	{
		cout << Message;
		cin >> number;
		cout << endl;

	} while (number <= 0);
	
	return number;
}

float DaysToSeconds(float Days) {
	
	float SecondsPerMinut = 24 * 60 * 60;
	float Seconds = Days * SecondsPerMinut;
	
	return Seconds;
}
float HoursToSeconds(float Hour) {
	
	float SecondsPerMinut = 60 * 60;
	float Seconds = Hour * SecondsPerMinut;
	
	return Seconds;
}
float MinutsToSeconds(float Minuts) {
	
	float SecondsPerMinut = 60;
	float Seconds = Minuts * SecondsPerMinut;
	
	return Seconds;
}

float TotalSeconds(float Days , float Hours , float Minuts, float Seconds) {

	float totalSeconds =
		  DaysToSeconds(Days)
		+ HoursToSeconds(Hours)
		+ MinutsToSeconds(Minuts)
		+ Seconds;

	return totalSeconds;
}

int main() {

	float NumberOfDays = ReadPositiveNumber("Enter The Number Of Days: ");
	float NumberOfHours = ReadPositiveNumber("Enter The Number Of Hours: ");
	float NumberOfMinuts = ReadPositiveNumber("Enter The Number Of Minuts: ");
	float NumberOfSeconds = ReadPositiveNumber("Enter The Number Of Seconds: ");
	

	cout << TotalSeconds(NumberOfDays, NumberOfHours, NumberOfMinuts, NumberOfSeconds) << endl;
	



	return 0;
}
