#include <iostream>
#include <string>
#include <cmath>
using namespace std;

void ReadPositiveNumber(int &base , int &m) {



	do {

		cout << "Enter a Positive Number: ";
		cin >> base;
		cout << endl;

		cout << "Enter The Power Number: ";
		cin >> m;
		cout << endl;

	} while (base <= 0 || m <=0);


}
int PowerOf(int base, int m) {

	int PowerResult = 1;

	for (int i = 1; i <= m;i++) {
		PowerResult *= base;
	}

	return PowerResult;
}
void PrintResult(int finalResult) {

	cout << finalResult << endl;
}

int main() {
	int base, m;

	ReadPositiveNumber(base, m);
	PrintResult(PowerOf(base, m));


	return 0;
}
