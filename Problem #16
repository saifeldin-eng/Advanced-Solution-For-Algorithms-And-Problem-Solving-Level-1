float CalculateRectagleAreaByDiagonalAndSideArea(float SideArea, float Diagonal) {

	return SideArea*sqrt(pow(Diagonal,2) - pow(SideArea,2));
}

void PrintResult(float RectagleArea) {

	cout << "\n Rectangle Area = " << RectagleArea << endl << endl;
}

int main() {
	float Diagonal, SideArea;

	ReadDiagonalAndSideArea(SideArea, Diagonal);

	PrintResult(CalculateRectagleAreaByDiagonalAndSideArea(SideArea, Diagonal));
	
	return 0;
}
