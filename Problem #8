#include <iostream>
#include <string>
using namespace std;

float readMark() {
	
	float mark;
do {
	cout << "Enter Your Mark: ";
	cin >> mark;
} while (mark < 0 || mark > 100);

return mark;

}
string getStudentStatus(float mark) {

	if (mark >= 50) {
		return "Passed";
	}
	else {
		return "Failed";
	}

}
void PrintResult(float mark) {

	cout << " The Student is " << getStudentStatus(mark);
}

int main() {

	PrintResult(readMark());


	return 0;
}
