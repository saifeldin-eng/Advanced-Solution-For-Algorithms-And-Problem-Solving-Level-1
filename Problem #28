#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadNumber(){

	int N;

	cout << "Please Enter Your Number: ";
	cin >> N;
	cout << endl;

	return N;

}

int SumOddNumFrom1ToN_UsingForLoop(int N) {
	cout << "\n For Loop \n";
	int sum = 0;
	for (int i = 1; i <= N; i= i+2) {

		sum += i;
	}

	return sum;
}
int SumOddNumFrom1ToN_UsingDoWhile(int N){

	cout << "\n Do While Loop \n";
	int sum = 0;
	int i = 1;
	do{
		
		sum += i;
		i = i + 2;
	
	} while (i < N);

	return sum;
}
int SumOddNumFrom1ToN_UsingWhile(int N){


	cout << "\n While Loop \n";
	int sum = 0;
	int i = 1;

	while (i < N) {

		
		sum += i ;

		i = i + 2;
	

	}
	return sum;

}

void PrintSumOddNumFrom1ToN(int N) {

	cout << SumOddNumFrom1ToN_UsingForLoop(N) << endl;
	cout << SumOddNumFrom1ToN_UsingDoWhile(N) << endl;
	cout << SumOddNumFrom1ToN_UsingWhile(N) << endl;
}

int main() {

	int Number = ReadNumber();

	
	PrintSumOddNumFrom1ToN(Number);
	return 0;
}
