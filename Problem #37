#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadNumber(string Message) {
	
	float number = 0;

	cout << Message;
	cin >> number;
	cout << endl;

	return number;
}

int SumUntilMinus99(int Number) {

	int sumNum = 0;

	while (Number != -99) {

		sumNum += Number;

		cout << "Enter Your Number: ";
		cin >> Number;
		cout << endl;
	}
	return sumNum;
}

int main() {

	int Number = ReadNumber("Please Enter Your Number to Sum: ");
	int sumNum = SumUntilMinus99(Number);

	cout << "Result: " << sumNum << endl;


}
