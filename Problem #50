#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadPINCode(string Message) {

	int number = 0;

	do
	{
		cout << Message;
		cin >> number;
		cout << endl;

	} while (number <= 0);

	return number;
}

bool CheckPIN(int PINCode) {

	int AccountPIN = 1234;

	if (PINCode == AccountPIN)
		return true;
	else
		return false;
}

float Balance() {

	return 7500;
}

string ATMAccount() {

	int PINCode = 0;
	int numOfTry = 0;
	
	while (numOfTry != 3) {

		PINCode = ReadPINCode("Please Enter PIN Code: ");
		numOfTry++;

		if (CheckPIN(PINCode))
			return "Your Balance = "+ to_string(Balance());
		else
			cout << "\nWrong PIN Code \n";
	}
		 

		return "Your Card Is Locked.";
		

}

int main() {
	
	
    
	cout << ATMAccount() << endl;
	

	return 0;
}
