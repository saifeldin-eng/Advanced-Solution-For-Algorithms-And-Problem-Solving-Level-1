#include <iostream>
#include <string>
#include <cmath>
using namespace std;

struct stCircleVaribles {

	float Radius = 1;
	const float PI = 3.14;
};

void ReadRadius(float &R) {



	cout << "Enter The Radius: ";
	cin >> R;
	cout << endl;


}

float CircleArea(float Radius , float PI) {

	return PI * pow(Radius ,2);
}

void PrintResult(float CircleArea) {

	cout << "\n Circle Area = " << CircleArea << endl << endl;
}

int main() {

	stCircleVaribles CircleVaribles;

	ReadRadius(CircleVaribles.Radius);
	PrintResult(CircleArea(CircleVaribles.Radius, CircleVaribles.PI));
	
	return 0;
}
