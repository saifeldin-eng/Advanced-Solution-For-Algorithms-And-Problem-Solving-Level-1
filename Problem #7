#include <iostream>
#include <string>
using namespace std;

struct stEnteredNumAndItHalf {

	float EnteredNumber;
	float HalfNumber;
};
stEnteredNumAndItHalf ReadNumber() {

	stEnteredNumAndItHalf NumAndItHalf;

	

	cout << "Enter Your Number: ";
	cin >> NumAndItHalf.EnteredNumber;
	cout << endl;

	return NumAndItHalf;
}
stEnteredNumAndItHalf HalfNumber(stEnteredNumAndItHalf NumAndItHalf) {

	NumAndItHalf.HalfNumber = NumAndItHalf.EnteredNumber / 2;

	return NumAndItHalf;

}
void PrintHalfNumber(stEnteredNumAndItHalf EnteredNumAndItHalf) {

	

	cout << " Half Number of " << EnteredNumAndItHalf.EnteredNumber << " is " << EnteredNumAndItHalf.HalfNumber;
	cout << endl;

}

int main() {

	PrintHalfNumber(HalfNumber(ReadNumber()));



	return 0;
}
