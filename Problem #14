#include <iostream>
#include <string>
using namespace std;
struct stNumber {

	int num1;
	int num2;
};
stNumber ReadNum() {

	stNumber num;
	cout << "Enter The First Number: ";
	cin >> num.num1;
	cout << endl;

	cout << "Enter The Second Number: ";
	cin >> num.num2;
	cout << endl;

	return num;

}

stNumber Swap2Number(stNumber num) {

	

	int temp;

	temp = num.num1;
	num.num1 = num.num2;
	num.num2 = temp;

	return num;
}

void PrintSwapNum(stNumber num) {
	
	cout << "The First Number is: " << num.num1 << endl;
	cout << "The Second Number is: " << num.num2 << endl;

}

int main() {


	PrintSwapNum(Swap2Number(ReadNum()));


	return 0;
}
