#include <iostream>
#include <string>
using namespace std;

void ReadMarks(float& Mark1, float& Mark2, float& Mark3) {

	cout << "Enter Mark 1: ";
	cin >> Mark1;
	cout << endl;

	cout << "Enter Mark 2: ";
	cin >> Mark2;
	cout << endl;

	cout << "Enter Mark 3: ";
	cin >> Mark3;
	cout << endl;

}
float SumMarks(float Mark1, float Mark2, float Mark3) {

	float Sum = (Mark1 + Mark2 + Mark3);
	return Sum;

}

float CalculateAvarage(float Mark1, float Mark2, float Mark3) {

	float Avarage = SumMarks(Mark1, Mark2, Mark3) / 3;
	return Avarage;
}

void PrintResult(float avarage) {

	if (avarage >= 50) {
	 cout << "The Avarage is: " << avarage << " , the student is passed";
	}
	else {
		cout << "The Avarage is: " << avarage << " , the student is failed";

	}


}

int main() {
	float Mark1, Mark2, Mark3;

	ReadMarks(Mark1, Mark2, Mark3);

	PrintResult(CalculateAvarage(Mark1, Mark2, Mark3));

	return 0;
}
