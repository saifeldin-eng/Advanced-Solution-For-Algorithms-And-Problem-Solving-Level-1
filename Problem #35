#include <iostream>
#include <string>
#include <cmath>
using namespace std;

void ReadPiggyBank(float &pennies, float&Nickles, float&Dimes, float&Quarters, float&Dollars) {


	cout << "Enter Total pennies: ";
	cin >> pennies;
	cout << endl;
	cout << "Enter Total Nickles: ";
	cin >> Nickles;
	cout << endl;
	cout << "Enter Total Dimes: ";
	cin >> Dimes;
	cout << endl;
	cout << "Enter Total Quarters: ";
	cin >> Quarters;
	cout << endl;
	cout << "Enter Total Dollars: ";
	cin >> Dollars;
	cout << endl;




}

float TotalPennies(float pennies, float Nickles, float Dimes, float Quarters, float Dollars){

	int TotalPennies = 0;

	TotalPennies += pennies;
	TotalPennies += Nickles *5;
	TotalPennies += Dimes *10;
	TotalPennies += Quarters *25;
	TotalPennies += Dollars *100;

	return TotalPennies;
}

float TotalDollars(float totalPennies) {

	return totalPennies / 100;
}

void PrintPiggyBank(float pennies, float Nickles, float Dimes, float Quarters, float Dollars) {

	float totalPennies = TotalPennies(pennies, Nickles, Dimes, Quarters, Dollars);


	cout << "Total Pennies = " << totalPennies << endl;
	cout << "Total Dollars = " << TotalDollars(totalPennies) << endl;
}

int main() {

	float pennies, Nickles, Dimes, Quarters, Dollars;

	ReadPiggyBank(pennies, Nickles, Dimes, Quarters, Dollars);
	PrintPiggyBank(pennies, Nickles, Dimes, Quarters, Dollars);
	

	return 0;
}
