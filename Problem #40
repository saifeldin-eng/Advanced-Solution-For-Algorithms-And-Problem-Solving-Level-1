#include <iostream>
#include <string>
#include <cmath>
using namespace std;

float ReadPositiveNumber(string Message) {
	
	float number = 0;
	do 
	{
		cout << Message;
		cin >> number;
		cout << endl;

	} while (number <= 0);
	

	return number;
}

float ServiceFree(){

	return 1.10;
}
float SalesTax(){

	return 1.16;
}

float TotalBill(float BillValue) {

	return	((ServiceFree() * BillValue) * SalesTax());
}
void PrintBillWithServiceFeeAndTax(int BillValue) {

	cout << "Service Fee:  " << (ServiceFree() - 1) * 100 << "%" << endl;
	cout << "Sales Tax:  " << (SalesTax() - 1) * 100 << "%" << endl;
	cout << "\n********************* \n";
	cout <<"Total Bill: " << TotalBill(BillValue) << endl;

}

int main() {

	float BillValue = ReadPositiveNumber("Please Enter Bill Value: ");

	PrintBillWithServiceFeeAndTax(BillValue);
	
}
