#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadAge(){

	int Age;

	cout << "Please Enter Your Age: ";
	cin >> Age;
	cout << endl;

	return Age;

}

bool ValidateNumberInRange(int Number , int From , int To) {

	return (Number >= From && Number <= To);
}

void PrintResult(int age) {

	while (!(ValidateNumberInRange(age, 18, 45))) {

		cout << "Invalid Age, Please Enter Avalid Age: ";
		cin >> age;
	}

	cout << "Your Age is " << age << ", it is a Valid Age.\n";

}

int main() {
	

	PrintResult(ReadAge());
	
	return 0;
}
