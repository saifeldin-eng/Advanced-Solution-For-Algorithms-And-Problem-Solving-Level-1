#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int ReadPositiveNumber(string Message) {

	int number = 0;

	do
	{
		cout << Message;
		cin >> number;
		cout << endl;

	} while (number <= 0);

	return number;
}

int numOfMonthToSettleTheLoan(int LoanAmount, int MonthlyPayment) {

	return LoanAmount / MonthlyPayment;
}

int main() {
	
	int LoanAmount = ReadPositiveNumber("Enter The Loan Amount: ");
	int MonthlyPayment = ReadPositiveNumber("Enter The Monthly Payment: ");

	cout << "You need " << numOfMonthToSettleTheLoan(LoanAmount, MonthlyPayment)
		 << " months to settle the loan."
		 << endl;
	

	return 0;
}
